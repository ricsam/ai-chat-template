{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "build-it.now:dev-tools.ts": ["../../../frontend-dev-tools.ts"],
      "build-it.now:modules.js": ["../../../frontend-modules.ts"],
      "@/env": ["../frontend-env.ts"],
      "@/shared/*": ["../shared/*"],
      "@/route-tree": ["../../runtime/route-tree.gen.ts"],
      "@/frontend/*": ["./*"],
      "@/components/*": ["../../../../src/components/*"],
      "@/lib/*": ["../../../../src/components/lib/*"],
      "streamdown/dist/*": ["../../../../node_modules/streamdown/dist/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "../../../frontend-dev-tools.ts",
    "../../../frontend-modules.ts",
    "../../runtime/route-tree.gen.ts",
    "../frontend-env.ts"
  ]
}
